{
  "name": "featureflow-lambda-edge-example",
  "scripts": {
    "build": "tsc --noEmit",
    "build:dist": "tsc",
    "deploy": "serverless deploy",
    "invoke:local": "serverless invoke local -f redirect -p events/cloudfront-request.json",
    "invoke:warm": "npm run build:dist && node scripts/invoke-warm.js"
  },
  "dependencies": {
    "featureflow-node-sdk": "^0.6.16"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.145",
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0"
  }
}
